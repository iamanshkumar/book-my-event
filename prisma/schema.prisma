datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(255)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  resetToken       String?   @map("reset_token") @db.VarChar(255)
  resetTokenExpiry DateTime? @map("reset_token_expiry")

  isVerified              Boolean   @default(false) @map("is_verified")
  verificationToken       String?   @map("verification_token") @db.VarChar(6)
  verificationTokenExpiry DateTime? @map("verification_token_expiry")

  allowedCurrencies Json?  @map("allowed_currencies")
  defaultCurrency   String @default("INR") @map("default_currency") @db.VarChar(10)

  events   Event[]
  bookings Booking[]
  address  OrganizerAddress?
  couponCodes CouponCode[]
  couponUsages CouponUsage[]

  @@map("users")
}

enum Role {
  CUSTOMER
  ORGANIZER
  ADMIN
}

model Event {
  id          Int           @id @default(autoincrement())
  organizerId Int           @map("organizer_id")
  eventName   String        @map("event_name") @db.VarChar(255)
  description String?       @db.VarChar(1000)
  location    String        @db.VarChar(255)
  country     String        @default("IND") @db.VarChar(10)
  pincode     String?       @db.VarChar(20)
  dateTime    DateTime      @map("date_time")
  duration    String        @db.VarChar(50)
  thumbnail   String?       @db.VarChar(500)
  banner      String?       @db.VarChar(500)
  trailerUrls Json?         @map("trailer_urls")
  category    EventCategory @default(OTHER)
  status      EventStatus   @default(DRAFT)
  createdAt   DateTime      @default(now()) @map("created_at")

  currency String @default("INR") @db.VarChar(10)

  minimumAge Int? @map("minimum_age")
  terms      String? @db.Text

  organizer   User         @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  ticketTiers TicketTier[]
  bookings    Booking[]
  couponUsages CouponUsage[]

  @@map("events")
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum EventCategory {
  TECH
  MUSIC
  SPORTS
  COMEDY
  MOVIES
  ARTS_THEATER
  BUSINESS
  FOOD_DRINK
  OTHER
}

model TicketTier {
  id                       Int     @id @default(autoincrement())
  eventId                  Int     @map("event_id")
  tierName                 String  @map("tier_name") @db.VarChar(255)
  totalSeats               Int     @map("total_seats")
  availableSeats           Int     @map("available_seats")
  pricePerSeatExcludingTax Decimal @map("price_per_seat_excluding_tax") @db.Decimal(10, 2)
  taxPercentage            Decimal @default(0.00) @map("tax_percentage") @db.Decimal(5, 2)

  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("ticket_tiers")
}

model Booking {
  id             Int           @id @default(autoincrement())
  userId         Int           @map("user_id")
  eventId        Int           @map("event_id")
  ticketTierId   Int           @map("ticket_tier_id")
  quantity       Int
  totalPricePaid Decimal       @map("total_price_paid") @db.Decimal(10, 2)
  paymentStatus  PaymentStatus @default(PENDING) @map("payment_status")
  createdAt      DateTime      @default(now()) @map("created_at")
  currency       String        @default("INR") @db.VarChar(10)

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  event      Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketTier TicketTier @relation(fields: [ticketTierId], references: [id], onDelete: Cascade)

  @@map("bookings")
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model Setting {
  id            Int    @id @default(autoincrement()) @map("settings_id")
  userId        Int    @default(0) @map("user_id")
  settingsName  String @map("settings_name") @db.VarChar(255)
  settingsValue String @map("settings_value") @db.Text

  @@unique([userId, settingsName])
  @@map("settings")
}

model OrganizerAddress {
  id          Int     @id @default(autoincrement()) @map("address_id")
  userId      Int     @unique @map("user_id")
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String  @db.VarChar(50)
  street1     String  @db.VarChar(255)
  street2     String? @db.VarChar(255)
  state       String  @db.VarChar(100)
  zipCode     String  @map("zip_code") @db.VarChar(20)
  country     String  @db.VarChar(100)
  phoneNumber String  @map("phone_number") @db.VarChar(50)
  companyName String  @default("") @map("company_name") @db.VarChar(255)

  @@map("organizer_address")
}

model CouponCode {
  id          Int      @id @default(autoincrement()) @map("coupon_id")
  userId      Int      @map("user_id")
  name        String   @db.VarChar(255)
  code        String   @db.VarChar(255)
  description String?  @db.VarChar(1000)
  type        String   @db.VarChar(50)
  amount      Float
  status      Int      @default(1)
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  eventId     String   @map("event_id") @db.Text

  usageLimitSameProduct       Int? @map("usage_limit_same_product")
  usageLimitDifferentProducts Int? @map("usage_limit_different_products")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages      CouponUsage[]

  @@unique([userId, code])
  @@index([code])
  @@map("coupon_codes")
}

model CouponUsage {
  id        Int      @id @default(autoincrement()) @map("coupon_usage_id")
  couponId  Int      @map("coupon_id")
  userId    Int      @map("user_id")
  productId Int      @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  coupon    CouponCode @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("coupon_usage")
}
