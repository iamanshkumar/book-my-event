datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(255)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  resetToken       String?   @map("reset_token") @db.VarChar(255)
  resetTokenExpiry DateTime? @map("reset_token_expiry")

  events   Event[]
  bookings Booking[]

  @@map("users")
}

enum Role {
  CUSTOMER
  ORGANIZER
  ADMIN
}

model Event {
  id          Int           @id @default(autoincrement())
  organizerId Int           @map("organizer_id")
  eventName   String        @map("event_name") @db.VarChar(255)
  description String?       @db.VarChar(1000)
  location    String        @db.VarChar(255)
  country     String        @default("IND") @db.VarChar(10)
  pincode     String?       @db.VarChar(20)
  dateTime    DateTime      @map("date_time")
  duration    String        @db.VarChar(50)
  thumbnail   String?       @db.VarChar(500)
  banner      String?       @db.VarChar(500)
  trailerUrls Json?         @map("trailer_urls")
  category    EventCategory @default(OTHER)
  status      EventStatus   @default(DRAFT)
  createdAt   DateTime      @default(now()) @map("created_at")

  organizer   User         @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  ticketTiers TicketTier[]
  bookings    Booking[]

  @@map("events")
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum EventCategory {
  TECH
  MUSIC
  SPORTS
  COMEDY
  MOVIES
  ARTS_THEATER
  BUSINESS
  FOOD_DRINK
  OTHER
}

model TicketTier {
  id                       Int     @id @default(autoincrement())
  eventId                  Int     @map("event_id")
  tierName                 String  @map("tier_name") @db.VarChar(255)
  totalSeats               Int     @map("total_seats")
  availableSeats           Int     @map("available_seats")
  pricePerSeatExcludingTax Decimal @map("price_per_seat_excluding_tax") @db.Decimal(10, 2)
  taxPercentage            Decimal @default(0.00) @map("tax_percentage") @db.Decimal(5, 2)

  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("ticket_tiers")
}

model Booking {
  id             Int           @id @default(autoincrement())
  userId         Int           @map("user_id")
  eventId        Int           @map("event_id")
  ticketTierId   Int           @map("ticket_tier_id")
  quantity       Int
  totalPricePaid Decimal       @map("total_price_paid") @db.Decimal(10, 2)
  paymentStatus  PaymentStatus @default(PENDING) @map("payment_status")
  createdAt      DateTime      @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  event      Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketTier TicketTier @relation(fields: [ticketTierId], references: [id], onDelete: Cascade)

  @@map("bookings")
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model GeneralSetting {
  id           Int     @id @default(autoincrement())
  userId       Int     @unique @default(0) @map("user_id")
  websiteTitle String  @default("BookMyEvent") @map("website_title") @db.VarChar(255)
  metaTitle    String  @default("BookMyEvent - Discover & Book Live Experiences") @map("meta_title") @db.VarChar(255)
  websiteLogo  String? @map("website_logo") @db.VarChar(500)
  heroHeading  String  @default("Unlock Unforgettable Live Experiences") @map("hero_heading") @db.VarChar(255)

  @@map("general_settings")
}

model SmtpSetting {
  id           Int    @id @default(autoincrement())
  userId       Int    @unique @default(0) @map("user_id")
  smtpServer   String @default("localhost") @map("smtp_server") @db.VarChar(255)
  smtpPort     Int    @default(587) @map("smtp_port")
  smtpProtocol String @default("TLS") @map("smtp_protocol") @db.VarChar(50)

  @@map("smtp_settings")
}

model CaptchaSetting {
  id                           Int     @id @default(autoincrement())
  userId                       Int     @unique @default(0) @map("user_id")
  captchaEnabledRegister       Boolean @default(false) @map("captcha_enabled_register")
  captchaEnabledForgotPassword Boolean @default(false) @map("captcha_enabled_forgot_password")
  captchaSiteKey               String  @default("") @map("captcha_site_key") @db.VarChar(255)
  captchaSecretKey             String  @default("") @map("captcha_secret_key") @db.VarChar(255)

  @@map("captcha_settings")
}
